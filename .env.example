# CareerSarthi — environment configuration
# Copy this file to .env and fill in the values, then run:
#   python -m careersarthi.auth      (one-time Gmail/Calendar OAuth consent)
#   careersarthi serve-mcp           (or docker compose up)

# ── LLM / ADK ──────────────────────────────────────────────────────────────
# Required. Used by every Gemini-backed ADK agent (google.adk.agents.Agent).
# Get one from https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ── Storage ────────────────────────────────────────────────────────────────
# Path to the local SQLite database file. Defaults to .data/careersarthi.db
# if unset — only set this if you want a non-default location.
DATABASE_PATH=.data/careersarthi.db

# Fernet key used to encrypt sensitive free-text fields (e.g. application
# notes) at rest in the database. REQUIRED in any shared or deployed
# environment (docker-compose.yml expects this to be set explicitly).
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left blank in local dev, storage.py auto-generates and persists a key
# next to the database file — fine for solo local use, NOT for anything shared.
STORAGE_ENCRYPTION_KEY=

# ── Audit log ──────────────────────────────────────────────────────────────
# Path to the append-only JSON-lines audit log. Defaults to .data/audit.log.
AUDIT_LOG_PATH=.data/audit.log

# ── Gmail + Calendar OAuth (inbox_tracker, deadline_guardian) ─────────────
# Path to the OAuth client credentials JSON downloaded from Google Cloud
# Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Desktop app).
GMAIL_CREDENTIALS_PATH=.secrets/gmail_credentials.json

# Path where the consented OAuth token is written by `python -m careersarthi.auth`
# and subsequently read by inbox_tracker / deadline_guardian.
GMAIL_TOKEN_PATH=.secrets/gmail_token.json

# ── Job fetcher (mcp_server/tools/job_fetcher.py) ──────────────────────────
# All three are optional — if unset, job_fetcher.py falls back to curated
# mock job listings, so the app still runs end-to-end without any of these.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JSEARCH_API_KEY=

# ── App runtime ────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG

# ── Career MCP server (mcp_server/server.py --http mode) ───────────────────
# Only used when serving over HTTP (e.g. in Docker/Cloud Run). Defaults
# shown below match docker-compose.yml's exposed port.
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080
